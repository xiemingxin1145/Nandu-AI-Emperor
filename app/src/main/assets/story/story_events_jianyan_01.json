[
  {
    "event_id": "jianyan_first_court_shock",
    "title": "建炎初议",
    "chapter": "第一章·南渡之始",
    "type": "main_story",
    "trigger": {"turn_min": 1, "turn_max": 1, "required_city": "yingtianfu"},
    "description": "靖康二年四月，汴京陷落，二帝北狩。康王赵构于应天府仓皇即位，改元建炎。朝堂之上，半数臣僚面色惨白，或低泣，或沉默。李纲执笏上前，声音沙哑：陛下，金兵旦夕可至淮北，今日唯有振军心、稳人望，方有一线生机。",
    "choices": [
      {"id": "appoint_li_gang", "text": "任李纲为右相，主持军政", "effects": {"courtStability": 8, "warFactionPower": 12, "peaceFactionPower": -8, "li_gang_loyalty": 15, "jinThreat": -3}},
      {"id": "stabilize_first", "text": "暂不急于任命，先安抚百官，稳住人心", "effects": {"courtStability": 12, "warFactionPower": 3, "peaceFactionPower": 3, "gold": -500, "popularSupport": 5}},
      {"id": "secret_negotiation", "text": "密令使臣赴金营，试探议和之路", "effects": {"peaceFactionPower": 10, "warFactionPower": -10, "courtStability": -5, "jinThreat": -8, "troopMorale": -8}}
    ],
    "npc_reactions": [{"npc_id": "li_gang", "stance": "urgent", "text": "陛下若能振作军心，社稷尚有可为。"}, {"npc_id": "qin_hui", "stance": "neutral", "text": "陛下初登大宝，宜徐图之。"}],
    "risk_tags": ["court_conflict", "jin_pressure", "legitimacy_risk"],
    "art_hint": "应天府朝堂，烛火昏黄，群臣面色惨白",
    "related_characters": ["zhao_gou", "li_gang", "qin_hui", "zong_ze"],
    "related_cities": ["yingtianfu"]
  },
  {
    "event_id": "zong_ze_guards_bianjing",
    "title": "宗泽北望",
    "chapter": "第一章·南渡之始",
    "type": "main_story",
    "trigger": {"turn_min": 2, "turn_max": 5, "required_npc_alive": "zong_ze"},
    "description": "东京留守宗泽遣使南下，奏折字字泣血：汴京城内义民尚存，河北义军踊跃来投，金兵虽占城郭，然民心未附。宗泽请旨，或赐粮草接济，或命大军北援，或允老臣招抚河北义军自行筹谋。",
    "choices": [
      {"id": "send_grain_to_zong_ze", "text": "拨粮草五万石接济东京留守", "effects": {"grain": -50000, "zong_ze_loyalty": 20, "troopMorale": 8, "warFactionPower": 10, "jinThreat": 5}},
      {"id": "authorize_recruit_rebels", "text": "授权宗泽自行招抚河北义军", "effects": {"zong_ze_loyalty": 25, "warFactionPower": 15, "courtStability": -5, "jinThreat": 8, "rebel_faction_power": 10}},
      {"id": "ignore_zong_ze", "text": "暂不回应，令使者等候", "effects": {"zong_ze_loyalty": -20, "troopMorale": -10, "warFactionPower": -8, "popularSupport": -5}}
    ],
    "npc_reactions": [{"npc_id": "zong_ze", "stance": "desperate", "text": "过河！过河！臣三呼渡河，死而后已。"}],
    "risk_tags": ["jin_retaliation", "supply_risk"],
    "art_hint": "老将宗泽立于汴京城头，仰望北方，残阳如血",
    "related_characters": ["zong_ze", "li_gang", "qin_hui"],
    "related_cities": ["yingtianfu", "kaifeng"]
