  {
    "event_id": "discover_yue_fei_soldier",
    "title": "军中一卒",
    "chapter": "第一章·南渡之始",
    "type": "talent_discovery",
    "trigger": {"turn_min": 3, "turn_max": 8, "required_city": "yingtianfu", "trigger_event": "edict_military_inspection"},
    "description": "巡视军营时，一名年轻士卒跃出队列，单膝跪地，抬头直视天子。小卒岳飞，行伍出身，习枪棒，通兵书。此人年不过二十四五，眼中有火，不像寻常兵卒。",
    "choices": [
      {"id": "promote_yue_fei_to_centurion", "text": "拔擢为百夫长，令其暂领小队", "effects": {"yue_fei_loyalty": 20, "yue_fei_rank": 1, "yue_fei_troops": 100, "troopMorale": 5, "warFactionPower": 3}},
      {"id": "test_yue_fei", "text": "令其演武，观其本领再作决断", "effects": {"yue_fei_loyalty": 10, "courtStability": 2}},
      {"id": "dismiss_yue_fei", "text": "斥退，令其归队", "effects": {"yue_fei_loyalty": -15, "troopMorale": -3}}
    ],
    "npc_reactions": [{"npc_id": "yue_fei", "stance": "determined", "text": "贼金破我山河，掳我二帝，小卒世受国恩，死不旋踵。"}],
    "risk_tags": [],
    "art_hint": "军营点将台，年轻士卒岳飞单膝跪地",
    "related_characters": ["yue_fei", "li_gang", "zhao_gou"],
    "related_cities": ["yingtianfu"]
  },
  {"event_id":"han_shizhong_requests_battle","title":"韩世忠请战","chapter":"第一章·南渡之始","type":"talent_discovery","trigger":{"turn_min":2,"turn_max":6},"description":"将领韩世忠入殿，抱拳请战，身上还带着旧战伤的痕迹。他请率本部水军巡江，若金兵南渡，愿拦于江上。","choices":[{"id":"give_han_shizhong_command","text":"授韩世忠江防之责","effects":{"han_shizhong_loyalty":18,"han_shizhong_rank":2,"cityDefense_jiankang":10,"warFactionPower":8,"jinThreat":-5}},{"id":"give_han_shizhong_troops","text":"拨精兵五千","effects":{"han_shizhong_loyalty":22,"han_shizhong_troops":5000,"gold":-2000,"grain":-10000}},{"id":"hold_han_shizhong","text":"暂留京中护卫","effects":{"han_shizhong_loyalty":-5,"courtStability":3}}],"npc_reactions":[{"npc_id":"han_shizhong","stance":"eager","text":"臣不要金银，只要战船和兵士。"}],"risk_tags":["jin_retaliation","supply_pressure"],"art_hint":"韩世忠抱拳请战，梁红玉立于其后","related_characters":["han_shizhong","liang_hongyu","qin_hui"],"related_cities":["yingtianfu","jiankang"]},
  {"event_id":"li_gang_dismissed","title":"李纲去位","chapter":"第一章·南渡之始","type":"main_story","trigger":{"turn_min":6,"turn_max":12,"condition":"peaceFactionPower > warFactionPower"},"description":"主和派联名上疏，言李纲主战激进，徒耗国库。历史上，李纲任右相仅七十五日便被罢黜，而现在，奏疏摆在案前。","choices":[{"id":"keep_li_gang","text":"驳回弹劾，继续任用李纲","effects":{"warFactionPower":15,"peaceFactionPower":-10,"courtStability":-8,"li_gang_loyalty":20,"jinThreat":5}},{"id":"transfer_li_gang","text":"明升暗降，外任李纲","effects":{"courtStability":5,"warFactionPower":-5,"peaceFactionPower":5,"li_gang_loyalty":-10}},{"id":"dismiss_li_gang","text":"允准弹劾，罢免李纲","effects":{"peaceFactionPower":12,"warFactionPower":-15,"troopMorale":-10,"courtStability":8,"li_gang_loyalty":-30}}],"npc_reactions":[{"npc_id":"li_gang","stance":"resigned","text":"金人从不曾因议和而退兵。"}],"risk_tags":["faction_war","morale_drop"],"art_hint":"夜色朝堂，李纲独立殿中，身影萧索","related_characters":["li_gang","qin_hui","zong_ze","zhao_gou"],"related_cities":["yingtianfu"]},
  {"event_id":"jin_army_crosses_huai","title":"金兵渡淮","chapter":"第二章·江淮震动","type":"jin_event","trigger":{"turn_min":8,"turn_max":15,"condition":"jinThreat > 40"},"description":"军报如雪片涌入：金军骑兵已越淮河，前锋抵达楚州附近。沿途州县或降或逃，守军溃散。","choices":[{"id":"fortify_huai_line","text":"急令韩世忠赴淮河布防","effects":{"jinThreat":-10,"troopMorale":8,"han_shizhong_loyalty":5,"grain":-20000,"cityDefense_chuzhou":15}},{"id":"retreat_to_jiangnan","text":"下令朝廷南撤","effects":{"courtStability":-5,"troopMorale":-12,"popularSupport":-10,"jinThreat":-15,"peaceFactionPower":8}},{"id":"scorched_earth","text":"令地方坚壁清野","effects":{"jinThreat":-8,"grain":-30000,"popularSupport":-15,"troopMorale":3}}],"npc_reactions":[{"npc_id":"han_shizhong","stance":"war","text":"给臣三万兵，臣守住淮河。"}],"risk_tags":["city_fall_risk","morale_collapse","refugee_crisis"],"art_hint":"淮河岸边，金军骑兵滚滚南来","related_characters":["han_shizhong","qin_hui","li_gang"],"related_cities":["chuzhou","yangzhou","jiankang"]},
  {"event_id":"yangzhou_panic_flee","title":"扬州惊变","chapter":"第二章·江淮震动","type":"city_crisis","trigger":{"turn_min":10,"turn_max":18,"condition":"jinThreat > 50","required_city":"yangzhou"},"description":"金军轻骑突袭扬州外围，消息传至城中，百姓顿时大乱。守将弃印出逃，粮草辎重随之散失。","choices":[{"id":"send_stabilize_force","text":"急派武将安抚军民","effects":{"cityDefense_yangzhou":10,"popularSupport":8,"troopMorale":5,"courtStability":3}},{"id":"execute_fleeing_officer","text":"捕拿弃城守将，军前斩首","effects":{"troopMorale":12,"courtStability":-3,"warFactionPower":5,"cityDefense_yangzhou":8}},{"id":"abandon_yangzhou","text":"放弃扬州，撤往江南","effects":{"jinThreat":-5,"popularSupport":-20,"troopMorale":-15,"grain":-15000}}],"npc_reactions":[{"npc_id":"han_shizhong","stance":"furious","text":"守将弃城，其罪当诛！"}],"risk_tags":["city_fall_risk","morale_collapse","refugee_crisis"],"art_hint":"扬州城内，夜半人潮涌动，火把四处","related_characters":["han_shizhong","qin_hui"],"related_cities":["yangzhou","jiankang"]},
